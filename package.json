{
  "name": "nadi",
  "version": "1.0.0",
  "description": "A personal life-signal tracking system.",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "env": "direnv allow",
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "typecheck": "tsc --noEmit",
    "db:docker:up": "docker compose up -d postgres",
    "db:docker:down": "docker compose down",
    "db:docker:logs": "docker compose logs -f postgres",
    "db:docker:psql": "docker compose exec postgres psql -U nadi -d nadi",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx db/migrate.ts",
    "db:seed": "tsx db/seed/mock-data.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "better-auth": "^1.6.18",
    "drizzle-orm": "^0.45.2",
    "next": "^16.2.9",
    "pg": "^8.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5.5.3",
    "vitest": "^4.1.8"
  },
  "private": true
}
