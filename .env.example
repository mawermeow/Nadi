# Nadi 環境變數
# 此檔案僅作為說明用途。
# 不要在這裡填入真實 secrets；本機請透過 `.envrc` 載入。

# 資料庫
# Phase 1 必填。
# App runtime 與 migration script 使用的 Neon Postgres 連線字串。
DATABASE_URL=
# 本機 Docker PostgreSQL 範例：
# DATABASE_URL=postgresql://nadi:nadi_local_dev@localhost:5432/nadi

# Phase 1 可選。
# 若 migration 連線與 runtime 使用的 pooled connection 不同，建議設定此值。
DIRECT_DATABASE_URL=
# 本機 Docker PostgreSQL 可先與 DATABASE_URL 使用相同值：
# DIRECT_DATABASE_URL=postgresql://nadi:nadi_local_dev@localhost:5432/nadi

# Auth / Account System
# Phase 9 必填。
# AUTH_SECRET 至少 32 字元，供 Better Auth session / cookie 加密與簽章使用。
# 可用 `openssl rand -base64 32` 產生。
AUTH_SECRET=
# App 對外 base URL，本機通常為 `http://localhost:3000`。
AUTH_URL=

# App 模式
# `local` 用於本機開發，`preview` 用於暫時部署環境，`production` 用於正式環境。
NADI_APP_MODE=local

# Debug 開關
# 只有在受保護的本機環境才建議設為 `true`。
NADI_DEBUG=false

# 離線同步開關
# 若要測試 local-first sync / device-to-account linking / local merge，可設為 `true`。
NADI_ENABLE_OFFLINE_SYNC=false

# Report 防護設定
# 保留給後續 report phases。
# 這些值已由 env schema 驗證，先保留命名，後續啟用 reports 時可直接沿用。
NADI_REPORT_MAX_RANGE_DAYS=365
NADI_CORRELATION_DEFAULT_WINDOW_HOURS=24
NADI_CORRELATION_MIN_SAMPLE_SIZE=5
